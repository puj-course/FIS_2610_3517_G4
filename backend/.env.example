# Copia este archivo a backend/.env y reemplaza los placeholders con tus credenciales reales.
# Tambien puedes omitir MONGO_URI y usar MONGO_USER/MONGO_PASSWORD si prefieres construirla por partes.
MONGO_URI=mongodb://<mongo-user>:<mongo-password>@<mongo-host-1>:27017,<mongo-host-2>:27017,<mongo-host-3>:27017/logistica_db?ssl=true&replicaSet=<replica-set>&authSource=admin&retryWrites=true&w=majority

# Configuracion del servidor
PORT=5000
JWT_SECRET=<jwt-secret>
GOOGLE_CLIENT_ID=<google-client-id>

# Servicio de correo
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<smtp-user>
EMAIL_PASS=<smtp-password>

# SMS opcional (Twilio) para fallback de recuperacion

TWILIO_ACCOUNT_SID=AC908db487d54737ad4be2bbd75a8b1780
TWILIO_AUTH_TOKEN=7328b01e30f7a28febc72776103d9562
TWILIO_PHONE_NUMBER=+17622396858

# OTP
OTP_EXPIRACION_MINUTOS=10
OTP_MAX_INTENTOS=5
OTP_COOLDOWN_SEGUNDOS=60
