# Conexion MongoDB por defecto para este proyecto.
# El host y la base quedan fijos al cluster correcto; solo debes completar credenciales.
MONGO_PROTOCOL=mongodb+srv
MONGO_HOST=cluster0.45cqzzh.mongodb.net
MONGO_DB_NAME=logistica_db
MONGO_OPTIONS=retryWrites=true&w=majority&authSource=admin
MONGO_USER=<mongo-user>
MONGO_PASSWORD=<mongo-password>

# Configuracion del servidor
PORT=5000
JWT_SECRET=syntix_super_secret_key_dev
GOOGLE_CLIENT_ID=<google-client-id>

# Servicio de correo
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<correo-smtp>
EMAIL_PASS=<password-app-smtp>

# OTP
OTP_EXPIRACION_MINUTOS=10
OTP_MAX_INTENTOS=5
OTP_COOLDOWN_SEGUNDOS=60
