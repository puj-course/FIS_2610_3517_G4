# Frontend environment example. Copy to apps/web/.env only for local/private use.
# Do not commit real credentials.

VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=<google-client-id>

# These variables may be consumed by local tooling or compose flows.
MONGO_URI=mongodb://<mongo-user>:<mongo-password>@<mongo-host>:27017/logistica_db?authSource=admin
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<smtp-user>
EMAIL_PASS=<smtp-password>
OTP_EXPIRACION_MINUTOS=10
OTP_MAX_INTENTOS=5
OTP_COOLDOWN_SEGUNDOS=60
GOOGLE_CLIENT_ID=<google-client-id>
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_PHONE_NUMBER=<twilio-phone-number>
